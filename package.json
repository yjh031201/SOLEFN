{
  "name": "solefn",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "install:all": "npm install --prefix frontend",
    "dev": "cd frontend && npm run dev",
    "dev:local": "cd frontend && npm run dev:local",
    "backend:dev": "cd backend && mvnw.cmd spring-boot:run",
    "backend:build": "cd backend && mvnw.cmd -q -DskipTests package"
  }
}
